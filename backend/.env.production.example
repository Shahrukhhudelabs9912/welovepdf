# ────────────────────────────────────────────────────────────────────
# PDFOrca Backend — Production Environment Template
# ────────────────────────────────────────────────────────────────────
# Copy to `.env` on your VPS and fill in real values.
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ────────────────────────────────────────────────────────────────────

ENVIRONMENT=production
APP_DEBUG=False

# ── Security (REQUIRED — app refuses to boot without these) ───────
JWT_SECRET=CHANGE_ME_RUN_python_dash_c_secrets_token_urlsafe_48
ADMIN_TOKEN=CHANGE_ME_RUN_python_dash_c_secrets_token_urlsafe_32
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── CORS (your frontend domain, comma-separated) ──────────────────
CORS_ORIGINS=https://pdforca.com,https://www.pdforca.com

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=pdforca
MONGO_DB_NAME=pdforca

# ── Rate limiting (Redis recommended for multi-worker) ─────────────
RATELIMIT_STORAGE_URI=redis://redis:6379/0

# ── Cloud AI (Groq free tier) ──────────────────────────────────────
USE_CLOUD_LLM=True
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# ── PDF processing ────────────────────────────────────────────────
LIBREOFFICE_PATH=/usr/bin/soffice
HEAVY_JOB_CONCURRENCY=1

# ── Gunicorn (production WSGI server) ──────────────────────────────
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=300

# ── Sentry error tracking (optional) ──────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Email (Resend — for contact form & password reset) ─────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@pdforca.com

# ── Contact form ──────────────────────────────────────────────────
CONTACT_TO_EMAIL=admin@pdforca.com
CONTACT_FROM_EMAIL=noreply@pdforca.com
