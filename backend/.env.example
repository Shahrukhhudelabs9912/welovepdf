# ────────────────────────────────────────────────────────────────────
# WeLovePDF Backend — Environment Template
# ────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ────────────────────────────────────────────────────────────────────

# ── Environment ────────────────────────────────────────────────────
# Set to "production" on your VPS. The app refuses to boot in production
# with insecure defaults (placeholder JWT, dev CORS, debug=true).
ENVIRONMENT=development
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated, no quotes) ──────────────────────────────
# Production example:
#   CORS_ORIGINS=https://welovepdf.com,https://www.welovepdf.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── MongoDB ────────────────────────────────────────────────────────
# Free Atlas cluster: https://www.mongodb.com/cloud/atlas
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=welovepdf
MONGO_DB_NAME=welovepdf

# ── JWT (auth) ─────────────────────────────────────────────────────
# 48+ random chars. Rotating this invalidates all logged-in sessions.
JWT_SECRET=CHANGE_ME_RUN_python_dash_c_secrets_token_urlsafe_48
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin token (for /api/admin/* endpoints) ───────────────────────
# 32+ random chars. Required in production.
ADMIN_TOKEN=CHANGE_ME_RUN_python_dash_c_secrets_token_urlsafe_32

# ── Cloud AI (Groq free tier) ──────────────────────────────────────
# Get a free key at https://console.groq.com (no credit card)
USE_CLOUD_LLM=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30

# ── Sentry error tracking (free tier) ──────────────────────────────
# Get a DSN at https://sentry.io (free tier: 5k errors/month)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── PDF processing helpers ─────────────────────────────────────────
# Poppler is required for pdf2image.
#   Windows: https://github.com/oschwartz10612/poppler-windows/releases
#   Linux:   apt install poppler-utils
POPPLER_PATH=

# ── File upload limits (bytes) ─────────────────────────────────────
FREE_MAX_UPLOAD_SIZE=26214400      # 25 MB
PRO_MAX_UPLOAD_SIZE=104857600      # 100 MB
MAX_UPLOAD_SIZE=104857600          # absolute hard ceiling

# ── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FREE_HOURLY=100/hour
RATE_LIMIT_PRO_HOURLY=1000/hour
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_AI=30/hour
RATE_LIMIT_PROCESSING=60/hour

# Multi-worker rate limit storage. Defaults to in-memory (single process).
# For multiple uvicorn workers behind a load balancer, point at Redis:
#   RATELIMIT_STORAGE_URI=redis://localhost:6379

# ── File cleanup sweeper ───────────────────────────────────────────
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_SECONDS=900       # 15 minutes
CLEANUP_RETENTION_SECONDS=3600     # 1 hour
CUSTOM_CLEANUP_DIRS=

# ── Email (password reset, optional for now) ───────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@welovepdf.com
RESEND_API_KEY=

# ── Contact form ─────────────────────────────────────────────────────
# Where contact-page messages are delivered. Leave empty to skip email
# delivery — submissions still get stored in MongoDB either way.
CONTACT_TO_EMAIL=support@welovepdf.app
CONTACT_FROM_EMAIL=noreply@welovepdf.app
