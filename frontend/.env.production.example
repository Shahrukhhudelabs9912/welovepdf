# ────────────────────────────────────────────────────────────────────
# PDFOrca Frontend — Production Environment Template
# ────────────────────────────────────────────────────────────────────
# Copy to `.env.production` (or `.env.local`) on your deployment host
# and fill in real values. NEVER commit the filled-in file to git.
# ────────────────────────────────────────────────────────────────────

# ── Backend API base URL (server-side only, NOT exposed to browser) ─
# The Next.js server-side proxy routes (app/api/*/route.ts) use this to
# reach the Python FastAPI backend. Do NOT use NEXT_PUBLIC_ prefix —
# that would leak the backend host into the browser bundle.
#
# Docker Compose / same-host: http://backend:8000/api
# Separate VPS:               https://api.pdforca.com/api
PYTHON_API_BASE=http://backend:8000/api

# ── Public site URL (used for SEO canonical URLs, OpenGraph, etc.) ──
NEXT_PUBLIC_SITE_URL=https://pdforca.com

# ── Google AdSense ─────────────────────────────────────────────────
# Set your publisher ID after AdSense approval.
# Ads only render when this is set — leave blank to disable.
# Example: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_ID=
